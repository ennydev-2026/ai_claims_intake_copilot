APP_ENV=local
LOG_LEVEL=INFO
APP_NAME=AI Claims Intake Copilot
APP_VERSION=0.2.0

GEMINI_API_KEY=REPLACE_WITH_YOUR_GEMINI_API_KEY
GEMINI_MODEL_EXTRACT=gemini-2.5-flash
GEMINI_MODEL_SUMMARY=gemini-2.5-flash
OLLAMA_ENABLED=true
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL_EXTRACT=llama3.2:1b
OLLAMA_MODEL_SUMMARY=llama3.2:1b

DATABASE_URL=postgresql+psycopg://claims:claims@db:5432/claimsdb
MOCK_JAVA_BASE_URL=http://mock-java:8081
DASHBOARD_API_BASE_URL=http://api:8000
ENABLE_POLICY_ENRICHMENT=true
ENABLE_JAVA_CALLBACK=true
